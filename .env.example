# Copy this file to .env or .env.local before starting the app:
# cp .env.example .env

# Required: PostgreSQL connection used by the app at runtime.
# Example with credentials:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/stillwaters
DATABASE_URL=postgresql://localhost:5432/stillwaters

# Optional: dedicated migration connection.
# If omitted, `npm run migrate` falls back to DATABASE_URL.
DB_MIGRATE_URL=postgresql://localhost:5432/stillwaters

# Optional in local development. Set this in deployed environments so password
# reset links point to the correct app URL.
APP_ORIGIN=http://localhost:3000

# Optional: configure both values to enable password reset emails through Mailgun.
# Leave both blank if you do not need outbound email locally.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
