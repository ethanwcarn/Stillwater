# PostgreSQL connection string. Create a database (e.g. stillwaters) and run db/schema.sql and db/seed.sql first.
# Example for local PostgreSQL (replace USER and PASSWORD with your credentials):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/stillwaters
DATABASE_URL=postgresql://localhost:5432/stillwaters

# Mailgun credentials for password reset emails.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.example.com
